# ===============================================================
# Maoyang site - Environment Variables
# Configure in Vercel -> Project -> Settings -> Environment Variables
# ===============================================================

# Order storage (REQUIRED for admin dashboard and order lookup)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin dashboard (REQUIRED for /admin.html)
ADMIN_KEY=
# Optional aliases supported by the API:
# MAOYANG_ADMIN_KEY=
# ORDER_ADMIN_KEY=

# SMTP order confirmation email (REQUIRED for customer email)
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Branding
BRAND_NAME=冒央会社
SITE_DOMAIN=joinvip.vip
SITE_URL=https://www.joinvip.vip
SUPPORT_CONTACT=QQ：2802632995 / WhatsApp：+1 4315093334 / Telegram：@MaoyangSupport

# Google login (optional, required to enable Google登录 button)
GOOGLE_CLIENT_ID=
# Optional alias supported by the API:
# MAOYANG_GOOGLE_CLIENT_ID=

# New user coupon amount
NEW_USER_BONUS=8.88

# Telegram bot order push (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Webhook (optional)
# ORDER_WEBHOOK_URL=
